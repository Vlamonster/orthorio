HEIGHT = 5;
WIDTH = 11;
AGENTS = 4;
TUNNEL_4 = true;
TUNNEL_6 = false;

path = array2d(1..AGENTS, Marker,
  [|(y: 1, x: 1, d: ">"), (y: 5, x: 11, d: ">")
   |(y: 2, x: 1, d: ">"), (y: 4, x: 11, d: ">")
   |(y: 4, x: 1, d: ">"), (y: 1, x: 11, d: ">")
   |(y: 5, x: 1, d: ">"), (y: 2, x: 11, d: ">")|]);

walls = array2d(1..HEIGHT, 1..WIDTH, [0 | _ in 1..HEIGHT, _ in 1..WIDTH]);
