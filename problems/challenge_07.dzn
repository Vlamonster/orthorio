HEIGHT = 5;
WIDTH = 15;
AGENTS = 4;
TUNNEL_4 = true;
TUNNEL_6 = true;

path = array2d(1..AGENTS, Marker,
  [|(y: 1, x: 1, d: ">"), (y: 5, x: 15, d: ">")
   |(y: 2, x: 1, d: ">"), (y: 4, x: 15, d: ">")
   |(y: 4, x: 1, d: ">"), (y: 1, x: 15, d: ">")
   |(y: 5, x: 1, d: ">"), (y: 2, x: 15, d: ">")|]);

walls = array2d(1..HEIGHT, 1..WIDTH, [0 | _ in 1..HEIGHT, _ in 1..WIDTH]);
